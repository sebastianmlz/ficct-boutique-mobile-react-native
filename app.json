{
  "expo": {
    "name": "FICCT Boutique",
    "slug": "ficct-boutique",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafaf9"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#9a3412",
      "androidMode": "default"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bo.edu.ficct.boutique",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#fafaf9"
      },
      "package": "bo.edu.ficct.boutique",
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos para buscar prendas similares."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir ubicación para mostrar la sucursal más cercana."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#9a3412"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "graphqlUrl": "https://ficct-boutique-backend-go-production.up.railway.app/graphql",
      "aiApiUrl": "https://ficct-ai-1093089304525.us-central1.run.app/api/v1",
      "eas": {
        "projectId": "a1b9da6a-715f-4229-b4a9-20c6546b1cdd"
      }
    },
    "owner": "victoroides-organization"
  }
}
